                        {
                            "type": "ListItem",
                            "annotations": [],
                            "inline_children": [
                                {
                                    "type": "Text",
                                    "inline_children": [],
                                    "content": "Without it: Evaluation becomes subjective, scope continues to grow, and projects become difficult to close."
                                }
                            ],
                            "doc_children": [],
                            "label": "-"
